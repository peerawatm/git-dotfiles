# Line endings
* text=auto eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mov binary
*.mp4 binary
*.zip binary
*.gz binary
*.tar binary

# Custom diff engines
*.pdf diff=pdf

# Lockfile conflict mitigation
package-lock.json merge=binary
yarn.lock merge=binary
pnpm-lock.yaml merge=binary
Cargo.lock merge=binary
go.sum merge=binary
